 LEFT join [AppVisionLens].AVL.TM_TRN_InfraTimesheetDetail D on b.TimesheetId = D.TimesheetId AND B.ProjectID=d.ProjectId        
 GROUP BY Parent_Accountid      
    ,Parent_AccountName      
    ,EsaProjectID,Projectname      
    ,EmployeeID,EmployeeName      
    ,IsNonESAAuthorized   
  
